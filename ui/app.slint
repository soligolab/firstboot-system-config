import { Button, ComboBox, GroupBox, LineEdit } from "std-widgets.slint";

// Finestra principale della procedura di first-boot. Tutte le proprietà sono
// sincronizzate da/verso il codice Rust tramite i getter/setter generati da Slint.
export component AppWindow inherits Window {
    title: root.window_title;
    width: 1120px;
    height: 780px;

    in-out property <string> window_title: "First Boot - User Configuration";
    in-out property <int> current_language_idx: 0;
    in-out property <[string]> language_options: ["English", "Italiano", "Deutsch", "Español"];
    in-out property <string> language_label: "Language";
    in-out property <image> current_language_flag;
    in-out property <string> current_language_flag_emoji: "🇬🇧";

    // Stato corrente dell'orologio di sistema letto dal backend.
    in-out property <string> current_date: "--/--/----";
    in-out property <string> current_time: "--:--:--";
    in-out property <int> current_timezone_idx: 1;
    in-out property <[string]> timezone_options: ["UTC", "Europe/Rome", "Europe/London", "America/New_York", "Asia/Tokyo"];
    in-out property <string> current_timezone_label: "Europe/Rome";
    in-out property <bool> show_time_settings: false;
    in-out property <string> status_message: "Ready.";

    in-out property <string> clock_date_label: "Date";
    in-out property <string> clock_time_label: "Time";
    in-out property <string> clock_timezone_label: "Timezone";
    in-out property <string> configure_time_label: "Configure time";
    in-out property <string> main_heading: "First boot configuration - users and permissions";
    in-out property <string> suggestion_text;

    // Profilo amministratore suggerito al primo avvio.
    in-out property <string> admin_title: "System administrator";
    in-out property <string> admin_description;
    in-out property <string> admin_username: "sysadmin";
    in-out property <string> admin_full_name: "System Administrator";
    in-out property <string> admin_password;
    in-out property <int> admin_permission_idx: 0;
    in-out property <string> admin_password_feedback: "";

    // Profilo installatore / tecnico di campo.
    in-out property <string> installer_title: "Installer";
    in-out property <string> installer_description;
    in-out property <string> installer_username: "fieldtech";
    in-out property <string> installer_full_name: "Field Installer";
    in-out property <string> installer_password;
    in-out property <int> installer_permission_idx: 1;
    in-out property <string> installer_password_feedback: "";

    // Profilo operatore finale con privilegi minimi.
    in-out property <string> viewer_title: "End user";
    in-out property <string> viewer_description;
    in-out property <string> viewer_username: "operator";
    in-out property <string> viewer_full_name: "End User Operator";
    in-out property <string> viewer_password;
    in-out property <int> viewer_permission_idx: 2;
    in-out property <string> viewer_password_feedback: "";

    in-out property <string> username_label: "Username";
    in-out property <string> full_name_label: "Full name";
    in-out property <string> password_label: "Password";
    in-out property <string> permissions_label: "Permissions";
    in-out property <[string]> permission_options: ["Full administrator", "Networking and system time", "Read only"];

    in-out property <string> apply_configuration_label: "Apply configuration";
    in-out property <string> backup_recovery_label: "Backup recovery";
    in-out property <string> factory_reset_label: "Factory reset";
    in-out property <string> note_password;

    in-out property <string> time_settings_heading: "Configure date, time and timezone";
    in-out property <string> current_date_input_label: "Current date";
    in-out property <string> current_time_input_label: "Current time";
    in-out property <string> time_format_hint;
    in-out property <string> cancel_label: "Cancel";
    in-out property <string> save_label: "Save";

    // Callback implementati in Rust e invocati dai controlli grafici.
    callback password_feedback(string, string) -> string;
    callback language_changed(int);
    callback apply_configuration();
    callback backup_recovery();
    callback factory_reset();
    callback open_time_settings();
    callback close_time_settings();
    callback save_time_settings();

    VerticalLayout {
        padding: 20px;
        spacing: 14px;

        // Barra superiore con selettore lingua, stato temporale e accesso al popup.
        HorizontalLayout {
            spacing: 12px;

            Rectangle {
                HorizontalLayout {
                    spacing: 8px;
                    Image {
                        width: 30px;
                        height: 22px;
                        source: root.current_language_flag;
                    }
                    Text {
                        text: root.current_language_flag_emoji;
                        visible: root.current_language_flag_emoji != "";
                    }
                    Text {
                        text: root.language_label;
                        font-weight: 600;
                    }
                    ComboBox {
                        model: root.language_options;
                        current-index <=> root.current_language_idx;
                        selected(_) => {
                            root.language_changed(root.current_language_idx);
                        }
                    }
                }
            }

            Rectangle {
                HorizontalLayout {
                    spacing: 12px;
                    Text {
                        text: root.clock_date_label + ": " + root.current_date;
                        font-weight: 600;
                    }
                    Text {
                        text: root.clock_time_label + ": " + root.current_time;
                        font-weight: 600;
                    }
                    Text {
                        text: root.clock_timezone_label + ": " + root.current_timezone_label;
                        font-weight: 600;
                    }
                }
            }
            Rectangle {
                horizontal-stretch: 1;
            }
            Button {
                text: root.configure_time_label;
                clicked => { root.open_time_settings(); }
            }
        }

        Text {
            text: root.main_heading;
            font-size: 24px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        Text {
            text: root.suggestion_text;
            color: #404040;
            horizontal-alignment: center;
        }

        // Le tre card riflettono i profili utente tipici del sistema.
        HorizontalLayout {
            spacing: 12px;

            GroupBox {
                title: root.admin_title;
                VerticalLayout {
                    spacing: 8px;
                    Text { text: root.admin_description; color: #505050; wrap: word-wrap; }
                    Text { text: root.username_label; }
                    LineEdit { text <=> root.admin_username; }
                    Text { text: root.full_name_label; }
                    LineEdit { text <=> root.admin_full_name; }
                    Text { text: root.password_label; }
                    LineEdit {
                        input-type: password;
                        text <=> root.admin_password;
                        edited(text) => {
                            root.admin_password_feedback = root.password_feedback(root.admin_title, text);
                        }
                    }
                    Text { text: root.admin_password_feedback; color: #505050; wrap: word-wrap; }
                    Text { text: root.permissions_label; }
                    ComboBox {
                        model: root.permission_options;
                        current-index <=> root.admin_permission_idx;
                    }
                }
            }

            GroupBox {
                title: root.installer_title;
                VerticalLayout {
                    spacing: 8px;
                    Text { text: root.installer_description; color: #505050; wrap: word-wrap; }
                    Text { text: root.username_label; }
                    LineEdit { text <=> root.installer_username; }
                    Text { text: root.full_name_label; }
                    LineEdit { text <=> root.installer_full_name; }
                    Text { text: root.password_label; }
                    LineEdit {
                        input-type: password;
                        text <=> root.installer_password;
                        edited(text) => {
                            root.installer_password_feedback = root.password_feedback(root.installer_title, text);
                        }
                    }
                    Text { text: root.installer_password_feedback; color: #505050; wrap: word-wrap; }
                    Text { text: root.permissions_label; }
                    ComboBox {
                        model: root.permission_options;
                        current-index <=> root.installer_permission_idx;
                    }
                }
            }

            GroupBox {
                title: root.viewer_title;
                VerticalLayout {
                    spacing: 8px;
                    Text { text: root.viewer_description; color: #505050; wrap: word-wrap; }
                    Text { text: root.username_label; }
                    LineEdit { text <=> root.viewer_username; }
                    Text { text: root.full_name_label; }
                    LineEdit { text <=> root.viewer_full_name; }
                    Text { text: root.password_label; }
                    LineEdit {
                        input-type: password;
                        text <=> root.viewer_password;
                        edited(text) => {
                            root.viewer_password_feedback = root.password_feedback(root.viewer_title, text);
                        }
                    }
                    Text { text: root.viewer_password_feedback; color: #505050; wrap: word-wrap; }
                    Text { text: root.permissions_label; }
                    ComboBox {
                        model: root.permission_options;
                        current-index <=> root.viewer_permission_idx;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #d7d7d7;
        }

        // Pulsanti principali che delegano l'azione al backend host.
        HorizontalLayout {
            spacing: 12px;

            Button {
                text: root.apply_configuration_label;
                clicked => { root.apply_configuration(); }
            }
            Button {
                text: root.backup_recovery_label;
                clicked => { root.backup_recovery(); }
            }
            Button {
                text: root.factory_reset_label;
                clicked => { root.factory_reset(); }
            }
        }

        // Area di log/stato dove vengono mostrati risultati e messaggi d'errore.
        Rectangle {
            border-color: #d7d7d7;
            border-width: 1px;
            border-radius: 10px;
            min-height: 130px;

            Text {
                x: 12px;
                y: 12px;
                width: parent.width - 24px;
                text: root.status_message;
                wrap: word-wrap;
            }
        }

        Text {
            text: root.note_password;
            color: #606060;
            horizontal-alignment: center;
        }
    }

    // Overlay modale per la modifica di data, ora e timezone.
    Rectangle {
        visible: root.show_time_settings;
        background: #00000066;
        width: parent.width;
        height: parent.height;

        Rectangle {
            width: 500px;
            height: 330px;
            background: #f7f7f7;
            border-color: #c8c8c8;
            border-width: 1px;
            border-radius: 10px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: root.time_settings_heading;
                    font-size: 20px;
                    font-weight: 700;
                }

                Text { text: root.current_date_input_label; }
                LineEdit {
                    text <=> root.current_date;
                }

                Text { text: root.current_time_input_label; }
                LineEdit {
                    text <=> root.current_time;
                }

                Text { text: root.clock_timezone_label; }
                ComboBox {
                    model: root.timezone_options;
                    current-index <=> root.current_timezone_idx;
                }

                Text {
                    text: root.time_format_hint;
                    color: #606060;
                }

                HorizontalLayout {
                    spacing: 10px;

                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: root.cancel_label;
                        clicked => { root.close_time_settings(); }
                    }
                    Button {
                        text: root.save_label;
                        clicked => { root.save_time_settings(); }
                    }
                }
            }
        }
    }
}
