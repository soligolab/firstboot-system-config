import { Button, ComboBox, GroupBox, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "First Boot - Configurazione Utenti";
    width: 1080px;
    height: 760px;

    in-out property <string> current_date: "--/--/----";
    in-out property <string> current_time: "--:--:--";
    in-out property <int> current_timezone_idx: 1;
    in-out property <string> current_timezone_label: "Europe/Rome";
    in-out property <bool> show_time_settings: false;

    in-out property <string> admin_username: "sysadmin";
    in-out property <string> admin_full_name: "System Administrator";
    in-out property <string> admin_password;
    in-out property <int> admin_permission_idx: 0;
    in-out property <string> admin_password_feedback: "";

    in-out property <string> installer_username: "fieldtech";
    in-out property <string> installer_full_name: "Field Installer";
    in-out property <string> installer_password;
    in-out property <int> installer_permission_idx: 1;
    in-out property <string> installer_password_feedback: "";

    in-out property <string> viewer_username: "operator";
    in-out property <string> viewer_full_name: "End User Operator";
    in-out property <string> viewer_password;
    in-out property <int> viewer_permission_idx: 2;
    in-out property <string> viewer_password_feedback: "";

    callback password_feedback(string, string) -> string;
    callback apply_configuration();
    callback backup_recovery();
    callback factory_reset();
    callback open_time_settings();
    callback close_time_settings();
    callback save_time_settings();

    VerticalLayout {
        padding: 20px;
        spacing: 14px;

        HorizontalLayout {
            spacing: 12px;
            Rectangle {
                HorizontalLayout {
                    spacing: 12px;
                    Text {
                        text: "Data: " + root.current_date;
                        font-weight: 600;
                    }
                    Text {
                        text: "Ora: " + root.current_time;
                        font-weight: 600;
                    }
                    Text {
                        text: "Timezone: " + root.current_timezone_label;
                        font-weight: 600;
                    }
                }
            }
            Rectangle {
                horizontal-stretch: 1;
            }
            Button {
                text: "Configura orario";
                clicked => { root.open_time_settings(); }
            }
        }

        Text {
            text: "Configurazione primo avvio - utenti e permessi";
            font-size: 24px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        Text {
            text: "Nomi suggeriti: sysadmin (amministratore), fieldtech (installatore), operator (utente finale).";
            color: #404040;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            spacing: 12px;

            GroupBox {
                title: "Amministratore di sistema";
                VerticalLayout {
                    spacing: 8px;
                    Text { text: "Username"; }
                    LineEdit { text <=> root.admin_username; }
                    Text { text: "Nome esteso"; }
                    LineEdit { text <=> root.admin_full_name; }
                    Text { text: "Password"; }
                    LineEdit {
                        input-type: password;
                        text <=> root.admin_password;
                        edited(text) => {
                            root.admin_password_feedback = root.password_feedback("Amministratore", text);
                        }
                    }
                    Text { text: root.admin_password_feedback; color: #505050; wrap: word-wrap; }
                    Text { text: "Permessi"; }
                    ComboBox {
                        model: ["Amministratore completo", "Rete e ora di sistema", "Sola visualizzazione"];
                        current-index <=> root.admin_permission_idx;
                    }
                }
            }

            GroupBox {
                title: "Installatore";
                VerticalLayout {
                    spacing: 8px;
                    Text { text: "Username"; }
                    LineEdit { text <=> root.installer_username; }
                    Text { text: "Nome esteso"; }
                    LineEdit { text <=> root.installer_full_name; }
                    Text { text: "Password"; }
                    LineEdit {
                        input-type: password;
                        text <=> root.installer_password;
                        edited(text) => {
                            root.installer_password_feedback = root.password_feedback("Installatore", text);
                        }
                    }
                    Text { text: root.installer_password_feedback; color: #505050; wrap: word-wrap; }
                    Text { text: "Permessi"; }
                    ComboBox {
                        model: ["Amministratore completo", "Rete e ora di sistema", "Sola visualizzazione"];
                        current-index <=> root.installer_permission_idx;
                    }
                }
            }

            GroupBox {
                title: "Utente finale";
                VerticalLayout {
                    spacing: 8px;
                    Text { text: "Username"; }
                    LineEdit { text <=> root.viewer_username; }
                    Text { text: "Nome esteso"; }
                    LineEdit { text <=> root.viewer_full_name; }
                    Text { text: "Password"; }
                    LineEdit {
                        input-type: password;
                        text <=> root.viewer_password;
                        edited(text) => {
                            root.viewer_password_feedback = root.password_feedback("Utente finale", text);
                        }
                    }
                    Text { text: root.viewer_password_feedback; color: #505050; wrap: word-wrap; }
                    Text { text: "Permessi"; }
                    ComboBox {
                        model: ["Amministratore completo", "Rete e ora di sistema", "Sola visualizzazione"];
                        current-index <=> root.viewer_permission_idx;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #d7d7d7;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: center;

            Button {
                text: "Applica configurazione";
                clicked => { root.apply_configuration(); }
            }
            Button {
                text: "Backup recovery";
                clicked => { root.backup_recovery(); }
            }
            Button {
                text: "Factory Reset";
                clicked => { root.factory_reset(); }
            }
        }

        Text {
            text: "Nota: il controllo complessità password è informativo (non blocca il salvataggio).";
            color: #606060;
            horizontal-alignment: center;
        }
    }

    Rectangle {
        visible: root.show_time_settings;
        background: #00000066;
        width: parent.width;
        height: parent.height;

        Rectangle {
            width: 500px;
            height: 330px;
            background: #f7f7f7;
            border-color: #c8c8c8;
            border-width: 1px;
            border-radius: 10px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: "Configurazione orario di sistema";
                    font-size: 20px;
                    font-weight: 700;
                }

                Text { text: "Data corrente"; }
                LineEdit {
                    text <=> root.current_date;
                }

                Text { text: "Ora corrente"; }
                LineEdit {
                    text <=> root.current_time;
                }

                Text { text: "Timezone"; }
                ComboBox {
                    model: ["UTC", "Europe/Rome", "Europe/London", "America/New_York", "Asia/Tokyo"];
                    current-index <=> root.current_timezone_idx;
                }

                Text {
                    text: "Formato suggerito: data GG/MM/AAAA, ora HH:MM:SS";
                    color: #606060;
                }

                HorizontalLayout {
                    spacing: 10px;
                    alignment: end;

                    Button {
                        text: "Annulla";
                        clicked => { root.close_time_settings(); }
                    }
                    Button {
                        text: "Salva";
                        clicked => { root.save_time_settings(); }
                    }
                }
            }
        }
    }
}
